# Airbnb Login
AIRBNB_EMAIL=deine@email.de
AIRBNB_PASSWORD=dein-passwort

# Optional: TOTP Secret fuer 2FA (Base32, z.B. aus Authenticator-App)
# AIRBNB_TOTP_SECRET=JBSWY3DPEHPK3PXP

# App-URL (lokal oder Produktions-URL)
APP_URL=https://deine-app.vercel.app

# CRON_SECRET aus .env.local (damit der Webhook autorisiert wird)
WEBHOOK_SECRET=dein-cron-secret
